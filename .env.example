# Google Maps JavaScript API key (required)
# Enable "Maps JavaScript API" in Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY=

# OpenSky Network credentials (optional — anonymous rate limit is ~10s)
# Free account: https://opensky-network.org/
VITE_OPENSKY_USERNAME=
VITE_OPENSKY_PASSWORD=

# ADS-B Exchange API key (optional fallback — better coverage)
# API access: https://www.adsbexchange.com/data/
VITE_ADSB_EXCHANGE_API_KEY=
